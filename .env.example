# =============================================================================
# AI Reception Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Groq API (for LLM inference via CrewAI) ---
GROQ_API_KEY=

# --- Google Calendar (for booking / availability) ---
# Path to your service-account JSON file, or the JSON string itself
GOOGLE_CALENDAR_CREDENTIALS=

# --- Database ---
# PostgreSQL connection string (used by SQLAlchemy / Alembic)
DATABASE_URL=

# --- Frontend (Next.js) ---
# Public URL of the backend API (used by the frontend at build/runtime)
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend (FastAPI) ---
# Secret key for JWT token signing
SECRET_KEY=

# Allowed origins for CORS (comma-separated, no spaces)
# Example: https://your-app.vercel.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Optional / Tuning ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO






















































