# Application
APP_NAME="AI Reception Agent"
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Security / JWT
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PostgreSQL (Supabase or local Docker)
# Local Docker example:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/reception_agent
# Supabase example:
# DATABASE_URL=postgresql+psycopg2://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/reception_agent

# SQLAlchemy pool (tune for Supabase / production)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_PRE_PING=true

# Groq LLM
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Calendar OAuth (Web application client)
# Redirect URI must match the Google Cloud Console Web client setting.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/calendar/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
